# Copy to .env for local dev. On Vercel, set these as Project Environment Variables instead.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/core_pt"

# --- Admin login (used by prisma/seed.ts to create the store admin account) ---
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="changeme123"

# Secret used to sign the admin session cookie (JWT). Set a long random value
# in production, e.g. `openssl rand -base64 32`.
ADMIN_SESSION_SECRET="dev-only-secret-change-me-in-production"

# --- SMTP (real email sending) ---
# Until these are filled in, bookings still succeed — the email content is
# shown as an in-app "未送信" preview instead of being sent (see lib/mail.ts).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="CORE.PT <no-reply@core-pt.studio>"
STORE_EMAIL="reserve@core-pt.studio"
